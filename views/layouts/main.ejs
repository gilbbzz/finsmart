<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%# Tag <%- %> digunakan untuk output HTML mentah (tidak di-escape) %>
  <%# Tag <%= %> digunakan untuk output variabel (auto-escape XSS) %>
  <title><%= typeof title !== 'undefined' ? title + ' — FinSmart' : 'FinSmart' %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    /* Reset & Base */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --primary:   #1D9E75;
      --primary-dk:#085041;
      --danger:    #ef4444;
      --warning:   #f59e0b;
      --bg:        #f8fafc;
      --surface:   #ffffff;
      --border:    #e2e8f0;
      --text:      #1e293b;
      --muted:     #64748b;
      --radius:    8px;
    }
    body { font-family: system-ui, -apple-system, sans-serif; background: var(--bg); color: var(--text); line-height: 1.6; }

    /* Navbar */
    .navbar { background: var(--primary-dk); color: white; padding: .75rem 1.5rem; display: flex; align-items: center; justify-content: space-between; }
    .navbar-brand { font-size: 1.25rem; font-weight: 700; color: white; text-decoration: none; }
    .navbar-user  { font-size: .875rem; opacity: .85; }

    /* Container */
    .container { max-width: 960px; margin: 0 auto; padding: 2rem 1.5rem; }

    /* Page header */
    .page-header { margin-bottom: 1.5rem; }
    .page-header h1 { font-size: 1.5rem; font-weight: 700; }
    .page-header p  { color: var(--muted); margin-top: .25rem; font-size: .9rem; }

    /* Badge */
    .badge { display: inline-block; padding: .2rem .65rem; border-radius: 999px; font-size: .75rem; font-weight: 600; }
    .badge-income  { background: #dcfce7; color: #166534; }
    .badge-expense { background: #fee2e2; color: #991b1b; }

    /* Alert */
    .alert { padding: 1rem 1.25rem; border-radius: var(--radius); margin-bottom: 1rem; font-size: .9rem; }
    .alert-info    { background: #eff6ff; border-left: 4px solid #3b82f6; }
    .alert-success { background: #f0fdf4; border-left: 4px solid #22c55e; }
    .alert-warning { background: #fffbeb; border-left: 4px solid var(--warning); }
    .alert-danger  { background: #fef2f2; border-left: 4px solid var(--danger); }

    /* Table */
    .table-wrapper { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
    table { width: 100%; border-collapse: collapse; }
    thead th { background: #f1f5f9; font-size: .8rem; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: var(--muted); padding: .75rem 1rem; text-align: left; }
    tbody tr { border-top: 1px solid var(--border); }
    tbody tr:hover { background: #f8fafc; }
    tbody td { padding: .75rem 1rem; font-size: .9rem; }

    /* Summary cards */
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-bottom: 1.5rem; }
    .stat-card  { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1rem 1.25rem; }
    .stat-label { font-size: .75rem; text-transform: uppercase; letter-spacing: .06em; color: var(--muted); }
    .stat-value { font-size: 1.4rem; font-weight: 700; margin-top: .25rem; }
    .stat-value.income  { color: #16a34a; }
    .stat-value.expense { color: var(--danger); }
    .stat-value.balance { color: var(--primary); }

    /* Footer */
    footer { text-align: center; padding: 2rem; font-size: .8rem; color: var(--muted); border-top: 1px solid var(--border); margin-top: 3rem; }
  </style>
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container">
    <%- body %>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>
